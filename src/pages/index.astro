---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Narrow March — Follow the Lamb into the Fire">

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <img src="/images/hero-banner.jpg" alt="A knight stands before a burning city, bearing the cross" />
    </div>
    <div class="hero-content">
      <p class="hero-label">For Men Who March the Narrow Path</p>
      <h1 class="hero-title">The Narrow<br/>March</h1>
      <div class="hero-line"></div>
      <p class="hero-tagline">"Do not follow the Lamb for comfort.<br/>Follow Him into the fire."</p>
      <div class="hero-ctas">
        <a href="/daily-crusader" class="btn btn-primary">Start the Daily Crusader</a>
        <a href="/newsletter" class="btn btn-outline btn-outline-light">Join the Newsletter</a>
      </div>
      <div class="hero-scroll">
        <span>&#8595;</span>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="section">
    <div class="container">
      <div class="mission">
        <div class="decorative-cross">&#10013;</div>
        <h2 class="section-title" style="text-align:center;">The War Has Never Ended</h2>
        <div class="decorative-line decorative-line-center"></div>
        <p class="mission-text">
          The Narrow March exists for men who understand that faith is not passive. It is active, costly, and daily.
          The crusade is internal before it is external. The enemy is not flesh and blood but principalities — and the battlefield is the heart.
        </p>
        <p class="mission-text">
          We are not building an audience. We are forging soldiers — armored in prayer, marching through cities of sin like salt through decay.
          Not soldiers of empire, but of eternity.
        </p>
      </div>
    </div>
  </section>

  <!-- Two Newsletter Cards -->
  <section class="section section-alt">
    <div class="container">
      <div class="newsletter-header">
        <h2 class="section-title" style="text-align:center;">Two Daily Weapons</h2>
        <p class="newsletter-header-sub">One for discipline. One for depth. Built to work together.</p>
      </div>
      <div class="newsletter-grid">
        <div class="card newsletter-card">
          <div class="card-accent-top"></div>
          <div class="icon-circle">&#9876;</div>
          <h3 class="card-title">The Daily Crusader</h3>
          <p class="card-subtitle">365 Days of Warrior Faith</p>
          <p class="card-desc">
            A devotional in your inbox every morning at 5 AM. Short, direct, rooted in Scripture — built to sharpen your discipline and anchor your day before the world gets a word in.
          </p>
          <div class="card-ctas">
            <a href="https://crusader.thenarrowmarch.com" class="btn btn-primary" target="_blank" rel="noopener">Subscribe</a>
            <a href="https://www.amazon.com/Daily-Crusader-Days-Faith-Discipline/dp/B0GQPW9THK" class="btn btn-outline" target="_blank" rel="noopener">Get the Book</a>
          </div>
        </div>
        <div class="card newsletter-card">
          <div class="card-accent-top"></div>
          <div class="icon-circle">&#128214;</div>
          <h3 class="card-title">The Narrow March</h3>
          <p class="card-subtitle">Daily Exegesis</p>
          <p class="card-desc">
            Every week, one passage. Every day, we go deeper. Daily exegesis tied to the week's sermon — so the Word isn't something you heard once. It's something you carry.
          </p>
          <a href="https://blog.thenarrowmarch.com" class="btn btn-primary" target="_blank" rel="noopener">Subscribe</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Verse Banner -->
  <section class="verse-banner">
    <div class="verse-bg">
      <img src="/images/banner-alt.jpg" alt="" />
    </div>
    <div class="container">
      <blockquote class="verse">
        <p>"Enter through the narrow gate. For wide is the gate and broad is the road that leads to destruction, and many enter through it. But small is the gate and narrow the road that leads to life, and only a few find it."</p>
        <cite>— Matthew 7:13-14</cite>
      </blockquote>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="section">
    <div class="container">
      <div class="about-teaser">
        <div class="about-teaser-img">
          <img src="/images/profile.jpg" alt="The Narrow March" />
        </div>
        <div class="about-teaser-text">
          <h2 class="section-title">The Modern Templar</h2>
          <div class="decorative-line"></div>
          <p>
            He rides no horse. He carries no banner. He moves unseen — armored in prayer.
            Marching through cities of sin like salt through decay. A soldier not of empire — but of eternity.
          </p>
          <a href="/about" class="btn btn-outline">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sermons Teaser -->
  <section class="section section-alt">
    <div class="container">
      <div class="sermons-teaser">
        <div class="icon-circle" style="margin: 0 auto 1.5rem;">&#9775;</div>
        <h2 class="section-title" style="text-align:center;">Sermons</h2>
        <div class="decorative-line decorative-line-center"></div>
        <p class="sermons-teaser-text">Verse-by-verse exposition through the books of the Bible. No cherry-picking. No skipping the hard parts.</p>
        <div style="text-align:center;">
          <a href="/sermons" class="btn btn-outline">Coming Soon</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ===== Hero ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.7) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem;
  }

  .hero-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--gold);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .hero-title {
    font-size: 5rem;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 30px rgba(0,0,0,0.5);
    line-height: 1.1;
  }

  .hero-line {
    width: 80px;
    height: 3px;
    background: var(--accent);
    margin: 0 auto 2rem;
    box-shadow: 0 0 12px var(--accent-glow);
  }

  .hero-tagline {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.85);
    font-style: italic;
    margin-bottom: 2.5rem;
    line-height: 1.8;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-outline-light {
    color: #fff;
    border-color: rgba(255,255,255,0.5);
  }

  .btn-outline-light:hover {
    background: #fff;
    color: #1a1a1a;
    border-color: #fff;
  }

  .hero-scroll {
    margin-top: 3rem;
    animation: bounce 2s infinite;
    color: rgba(255,255,255,0.4);
    font-size: 1.5rem;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(8px); }
  }

  /* ===== Mission ===== */
  .mission {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .mission .section-title {
    margin-bottom: 0.5rem;
  }

  .mission-text {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    line-height: 1.9;
  }

  /* ===== Newsletter Grid ===== */
  .newsletter-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .newsletter-header-sub {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-top: 0.5rem;
  }

  .newsletter-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
  }

  .newsletter-card {
    text-align: center;
    position: relative;
    overflow: hidden;
    padding-top: 3rem;
  }

  .card-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), var(--gold));
  }

  .newsletter-card .icon-circle {
    margin: 0 auto 1.25rem;
  }

  .card-title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .card-subtitle {
    font-size: 0.8rem;
    color: var(--gold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .card-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 2rem;
    line-height: 1.8;
  }

  .card-ctas {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ===== Verse Banner ===== */
  .verse-banner {
    position: relative;
    padding: 6rem 0;
    overflow: hidden;
  }

  .verse-bg {
    position: absolute;
    inset: 0;
  }

  .verse-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .verse-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.8);
  }

  .verse {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
  }

  .verse p {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    line-height: 1.8;
    color: #fff;
    font-style: italic;
  }

  .verse cite {
    display: block;
    margin-top: 1.5rem;
    font-size: 0.85rem;
    color: var(--gold);
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ===== About Teaser ===== */
  .about-teaser {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: center;
  }

  .about-teaser-img img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border: 3px solid var(--accent);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
  }

  .about-teaser-text p {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.9;
    font-style: italic;
    margin-bottom: 2rem;
  }

  /* ===== Sermons Teaser ===== */
  .sermons-teaser {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .sermons-teaser-text {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 3rem;
    }

    .hero-tagline {
      font-size: 1rem;
    }

    .newsletter-grid {
      grid-template-columns: 1fr;
    }

    .about-teaser {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .about-teaser-img img {
      max-width: 220px;
      margin: 0 auto;
    }

    .about-teaser-text .decorative-line {
      margin: 0 auto 1.5rem;
    }
  }
</style>
